import("//build/test.gni")
import("//foundation/multimedia/media_library/media_library.gni")

group("unittest") {
  testonly = true
  deps = [ ":media_cloud_sync_data_vo_test" ]
}

ohos_unittest("media_cloud_sync_data_vo_test") {
  cflags = [
    "-std=c++17",
    "-fno-rtti",
    "-fno-exceptions",
    "-Wall",
    "-fno-common",
    "-fstack-protector-strong",
    "-Wshadow",
    "-FPIC",
    "-FS",
    "-O2",
    "-D_FORTIFY_SOURCE=2",
    "-Wformat=2",
    "-Wfloat-equal",
    "-Wdate-time",
    "-Werror",
    "-Wimplicit-fallthrough",
    "-Wsign-compare",
  ]

  module_out_path = "media_library/medialibrary-data"
  include_dirs = [
    "./include",
    "${MEDIALIB_CLOUD_SYNC_DATA}/include",
    "${MEDIALIB_CLOUD_SYNC_DATA}/include/vo",
    "${MEDIALIB_IPC_COMMON}/include/utils",
    "${MEDIALIB_IPC_COMMON}/include/vo",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension/include/orm",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension/include/orm/po",
    "${MEDIALIB_TEST_PATH}/unittest/get_self_permissions/include/",
    "${MEDIALIB_INTERFACES_PATH}/inner_api/media_library_helper/include",
    "${MEDIALIB_UTILS_PATH}/include",
  ]

  sources = [
    "./src/cloud_error_detail_vo_test.cpp",
    "./src/cloud_file_data_vo_test.cpp",
    "./src/cloud_mdkrecord_photo_album_vo_test.cpp",
    "./src/cloud_mdkrecord_photos_vo_test.cpp",
    "./src/cloud_sync_unprepared_data_vo_test.cpp",
    "./src/failed_size_resp_vo_test.cpp",
    "./src/get_aging_file_vo_test.cpp",
    "./src/get_check_records_vo_test.cpp",
    "./src/get_cloud_thm_stat_vo_test.cpp",
    "./src/get_dirty_type_stat_vo_test.cpp",
    "./src/get_download_asset_vo_test.cpp",
    "./src/get_download_thm_by_uri_vo_test.cpp",
  ]

  deps = [
    "${MEDIALIB_CLOUD_SYNC_DATA}:media_cloud_sync_data",
    "${MEDIALIB_IPC_COMMON}:media_ipc_common",
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper:media_library",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_core",
    "ipc:ipc_single",
    "data_share:datashare_common",
    "data_share:datashare_provider",
    "relational_store:native_rdb",
    "relational_store:rdb_data_share_adapter",
  ]

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }

  resource_config_file =
      "${MEDIALIB_INNERKITS_PATH}/test/unittest/resources/ohos_test.xml"
}
