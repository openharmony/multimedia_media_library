import("//build/test.gni")
import("//foundation/multimedia/media_library/media_library.gni")

group("unittest") {
  testonly = true
  deps = [ ":media_library_upgrade_schema_test" ]
}

ohos_unittest("media_library_upgrade_schema_test") {
  module_out_path = "media_library/media_library_asset"
  include_dirs = [
    "./include",
    "${MEDIALIB_BUSINESS_PATH}/media_rdbstore/include",
    "${MEDIALIB_BUSINESS_PATH}/media_rdbstore/include/upgrade",
    "${MEDIALIB_BUSINESS_PATH}/media_rdbstore/include/rdbstore",
    "${MEDIALIB_BUSINESS_PATH}/media_rdbstore/include/event_handler",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/include",
    "${MEDIALIB_INTERFACES_PATH}/inner_api/media_library_helper/include",
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper/include",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension/include",
    "${MEDIALIB_UTILS_PATH}/include",
    "${MEDIALIB_COMMON_PATH}/include",
    "${MEDIALIB_SERVICES_PATH}/media_async_worker/include",
    "${MEDIALIB_THUMBNAIL_PATH}/include",
    "${MEDIALIB_BUSINESS_PATH}/media_analysis_data_manager/include/dao/table",
  ]

  cflags_cc = [
    "-fno-access-control",
  ]

  sources = [
    "./src/media_library_upgrade_schema_test.cpp",
  ]

  deps = [
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper:media_library",
    "${MEDIALIB_COMMON_PATH}:media_library_common",
    "${MEDIALIB_UTILS_PATH}:permission_utils",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension:medialibrary_data_extension",
  ]

  external_deps = [
    "ability_base:want",
    "ability_base:zuri",
    "ability_runtime:ability_context_native",
    "ability_runtime:ability_manager",
    "ability_runtime:abilitykit_native",
    "access_token:libaccesstoken_sdk",
    "access_token:libnativetoken_shared",
    "access_token:libprivacy_sdk",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "data_share:datashare_common",
    "data_share:datashare_consumer",
    "data_share:datashare_provider",
    "dfs_service:cloudsync_kit_inner",
    "dfs_service:libdistributedfileutils_lite",
    "e2fsprogs:libext2_uuid",
    "ffrt:libffrt",
    "hilog:libhilog",
    "hitrace:hitrace_meter",
    "hisysevent:libhisysevent",
    "init:libbegetutil",
    "ipc:ipc_core",
    "kv_store:distributeddata_inner",
    "napi:ace_napi",
    "netmanager_base:net_conn_manager_if",
    "os_account:os_account_innerkits",
    "player_framework:media_client",
    "preferences:native_preferences",
    "relational_store:native_rdb",
    "relational_store:rdb_data_share_adapter",
  ]

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
}