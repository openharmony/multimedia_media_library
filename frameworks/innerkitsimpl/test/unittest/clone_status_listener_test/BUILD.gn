import("//build/test.gni")
import("//foundation/multimedia/media_library/media_library.gni")
 
group("unittest") {
  testonly = true
  deps = [ ":clone_status_listener_test" ]
}
 
ohos_unittest("clone_status_listener_test") {
  module_out_path = "media_library/medialibrary-album"
  include_dirs = [
    "${MEDIALIB_NEW_SERVICES_PATH}/background_task_manager/include",
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper/include",
    "${MEDIALIB_UTILS_PATH}/include",
    "../medialibrary_unittest_utils/include",
    "./include",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/include",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_cloud_sync/include",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_library/include",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_library/include/async_worker",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_library/include/framework",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_library/include/thumbnail",
    "${MEDIALIB_ROOT_SERVICES_PATH}/media_cloud_sync_notify_handle/include",
  ]
 
  cflags_cc = [ "-fno-access-control" ]
 
  sources = [
    "./src/clone_status_listener_test.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/background_task_manager/src/clone_status_listener.cpp",
  ]
 
  deps = [
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper:media_library",
    "${MEDIALIB_COMMON_PATH}:media_library_common",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension:medialibrary_data_extension",
  ]
 
  external_deps = [
    "ability_runtime:ability_connect_callback_stub",
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "init:libbeget_proxy",
    "init:libbegetutil",
    "ipc:ipc_single",
    "samgr:samgr_proxy",
  ]
}