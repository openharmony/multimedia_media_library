import("//build/test.gni")
import("//foundation/multimedia/media_library/media_library.gni")
 
group("unittest") {
  testonly = true
  deps = [ ":media_lake_file_monitor_test" ]
}
 
ohos_unittest("media_lake_file_monitor_test") {
  module_out_path = "media_library/media_library_asset"
  include_dirs = [
    "./include",
    "../medialibrary_unittest_utils/include",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/include",
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper/include",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/include",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/include",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/include",
  ]

  cflags = [ "-fno-access-control" ]
 
  media_lake_scanner_source = [
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/folder_scanner.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/folder_scanner_utils.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/global_scanner.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/file_scanner.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/folder_scanner_helper.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/media_lake_check_manager.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_scanner/src/media_lake_check.cpp",
  ]
 
  media_load_lake_source = [
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/src/file_parser.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/src/lake_file_utils.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/src/folder_parser.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/src/lake_file_operations.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_load/src/product_info.cpp",
  ]
 
  media_lake_file_monitor_source = [
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/file_monitor_wrapper.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_delete_dir_processor.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_delete_file_processor.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_file_change_manager.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_file_change_processor.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_file_notify_processor.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_lake_clone_event_manager.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_lake_monitor_rdb_utils.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_lake_file_monitor/src/media_delete_lake_dir_processor.cpp",
  ]
 
  media_lake_file_handle_source = [
    "${MEDIALIB_CLOUD_SYNC_SERVICE_PATH}/src/service/cloud_lake_file_handler.cpp",
    "${MEDIALIB_SERVICES_PATH}/media_cloud_sync_notify_handle/src/lake_file_handler.cpp"
  ]
 
  sources = [
    "./src/lake_file_monitor_test.cpp",
    "./src/lake_monitor_rdb_test.cpp",
    "./src/media_lake_clone_event_manager_test.cpp",
    "../medialibrary_unittest_utils/src/medialibrary_unittest_utils.cpp",
    "${MEDIALIB_NEW_SERVICES_PATH}/media_rdbstore/src/rdbstore/media_upgrade.cpp",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/src/dfx_anco_manager.cpp",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/src/dfx_reporter.cpp",
    "${MEDIALIB_SERVICES_PATH}/media_dfx/src/dfx_utils.cpp",
  ]
  sources += media_lake_scanner_source
  sources += media_load_lake_source
  sources += media_lake_file_monitor_source
  sources += media_lake_file_handle_source
 
  deps = [
    "${MEDIALIB_INNERKITS_PATH}/media_library_helper:media_library",
    "${MEDIALIB_COMMON_PATH}:media_library_common",
    "${MEDIALIB_INNERKITS_PATH}/medialibrary_data_extension:medialibrary_data_extension",
  ]
 
  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "ability_base:zuri",
    "ability_runtime:ability_connect_callback_stub",
    "ability_runtime:ability_context_native",
    "ability_runtime:ability_manager",
    "ability_runtime:abilitykit_native",
    "ability_runtime:app_context",
    "ability_runtime:app_manager",
    "ability_runtime:dataobs_manager",
    "ability_runtime:extensionkit_native",
    "ability_runtime:napi_base_context",
    "ability_runtime:runtime",
    "ability_runtime:uri_permission_mgr",
    "access_token:libaccesstoken_sdk",
    "access_token:libprivacy_sdk",
    "app_file_service:sandbox_helper_native",
    "background_task_mgr:bgtaskmgr_innerkits",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "data_share:datashare_common",
    "data_share:datashare_consumer",
    "data_share:datashare_provider",
    "dfs_service:libdistributedfileutils_lite",
    "drivers_interface_display:display_commontype_idl_headers",
    "e2fsprogs:libext2_uuid",
    "eventhandler:libeventhandler",
    "ffrt:libffrt",
    "file_api:filemgmt_libn",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "hitrace:hitrace_meter",
    "i18n:intl_util",
    "image_framework:image_native",
    "init:libbeget_proxy",
    "init:libbegetutil",
    "ipc:ipc_core",
    "ipc:ipc_single",
    "ipc:ipc_napi",
    "kv_store:distributeddata_inner",
    "libexif:libexif",
    "libfuse:libfuse",
    "libxml2:libxml2",
    "napi:ace_napi",
    "netmanager_base:net_conn_manager_if",
    "os_account:libaccountkits",  # ohos_account
    "os_account:os_account_innerkits",  # os_account
    "player_framework:media_client",
    "player_framework:video_editor",
    "preferences:native_preferences",
    "qos_manager:qos",
    "qos_manager:concurrent_task_client",
    "relational_store:native_rdb",
    "relational_store:rdb_data_share_adapter",
    "resource_schedule_service:ressched_client",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
    "storage_service:storage_manager_sa_proxy",
    "thermal_manager:thermalsrv_client",
    "usb_manager:usbsrv_client",
    "window_manager:libdm",
    "zlib:shared_libz",
  ]
 
  defines = []
 
  if (defined(global_parts_info) &&
      defined(global_parts_info.filemanagement_dfs_service)) {
    defines += [ "CLOUD_SYNC_MANAGER" ]
    external_deps += [ "dfs_service:cloudsync_kit_inner" ]
  }
 
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
}
